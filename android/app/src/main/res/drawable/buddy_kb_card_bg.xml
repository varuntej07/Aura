<?xml version="1.0" encoding="utf-8"?>
<!-- A draft card on the whiteboard: cream rounded surface with a soft border, with a
     pale teal flash on press so it reads as tappable (tap a card to insert it). -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/buddy_kb_key_pressed" />
            <corners android:radius="14dp" />
            <stroke android:width="1dp" android:color="@color/buddy_kb_accent" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/buddy_kb_key" />
            <corners android:radius="14dp" />
            <stroke android:width="1dp" android:color="@color/buddy_kb_border" />
        </shape>
    </item>
</selector>
