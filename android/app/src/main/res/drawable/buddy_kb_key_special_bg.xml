<?xml version="1.0" encoding="utf-8"?>
<!-- A function key (shift, backspace, ?123, enter, emoji): rounded darker fill with a hairline
     border and the same simple fill highlight on press as the character keys, so all keys feel
     consistent and flat (Gboard-like). -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/buddy_kb_key_pressed" />
            <corners android:radius="11dp" />
            <stroke android:width="1dp" android:color="@color/buddy_kb_border" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/buddy_kb_key_special" />
            <corners android:radius="11dp" />
            <stroke android:width="1dp" android:color="@color/buddy_kb_border" />
        </shape>
    </item>
</selector>
