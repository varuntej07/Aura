<?xml version="1.0" encoding="utf-8"?>
<!-- Background for the key-preview bubble and the long-press accent popup. A light raised
     surface with a soft border, matching the keyboard's warm cream palette. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="@color/buddy_kb_key" />
    <corners android:radius="10dp" />
    <stroke
        android:width="1dp"
        android:color="@color/buddy_kb_border" />
</shape>
