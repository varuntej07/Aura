<?xml version="1.0" encoding="utf-8"?>
<!-- A single character key: rounded (Gboard-like) rect with a hairline border, and a simple
     fill highlight on press (no scale, no teal flash) for snappy, flat feedback. The border color
     is themed (subtle in light, near-invisible in dark). -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/buddy_kb_key_pressed" />
            <corners android:radius="11dp" />
            <stroke android:width="1dp" android:color="@color/buddy_kb_border" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/buddy_kb_key" />
            <corners android:radius="11dp" />
            <stroke android:width="1dp" android:color="@color/buddy_kb_border" />
        </shape>
    </item>
</selector>
