<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <application
        android:label="Aura"
        android:name="${applicationName}"
        android:icon="@mipmap/ic_launcher">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:taskAffinity=""
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize">
            <!-- Specifies an Android theme to apply to this Activity as soon as
                 the Android process has started. This theme is visible to the user
                 while the Flutter UI initializes. After that, this theme continues
                 to determine the Window background behind the Flutter UI. -->
            <meta-data
              android:name="io.flutter.embedding.android.NormalTheme"
              android:resource="@style/NormalTheme"
              />
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
            <!-- aura://voice deep link: the Voice Launcher primitive every surface
                targets to open straight into voice. -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW"/>
                <category android:name="android.intent.category.DEFAULT"/>
                <category android:name="android.intent.category.BROWSABLE"/>
                <data android:scheme="aura" android:host="voice"/>
            </intent-filter>
            <!-- https App Link to the same voice entry, verified by
                 /.well-known/assetlinks.json on auravoiceapp.com, so a shared link opens
                 Buddy voice directly instead of a browser. -->
            <intent-filter android:autoVerify="true">
                <action android:name="android.intent.action.VIEW"/>
                <category android:name="android.intent.category.DEFAULT"/>
                <category android:name="android.intent.category.BROWSABLE"/>
                <data android:scheme="https" android:host="auravoiceapp.com" android:pathPrefix="/voice"/>
            </intent-filter>
        </activity>

        <!-- Buddy Keyboard: the in-app IME (a separate OS-managed input method).
             BIND_INPUT_METHOD is granted to the system so it can bind this service;
             method.xml declares the keyboard subtype. -->
        <service
            android:name=".keyboard.BuddyImeService"
            android:label="@string/buddy_keyboard_label"
            android:permission="android.permission.BIND_INPUT_METHOD"
            android:exported="true">
            <intent-filter>
                <action android:name="android.view.InputMethod" />
            </intent-filter>
            <meta-data
                android:name="android.view.im"
                android:resource="@xml/method" />
        </service>
        <!-- Aura voice widget: a home-screen button that opens the app straight into
             a voice session (one tap, mic on). The tap PendingIntent (built in
             VoiceWidgetProvider) launches MainActivity with the voice launch action. -->
        <receiver
            android:name=".widget.VoiceWidgetProvider"
            android:exported="false"
            android:label="@string/voice_widget_label">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/voice_widget_info" />
        </receiver>

        <!-- Digital assistant (opt-in): once the user picks Buddy as the assistant app,
             the assist gesture opens Buddy voice. No effect unless selected. -->
        <service
            android:name=".assistant.BuddyVoiceInteractionService"
            android:permission="android.permission.BIND_VOICE_INTERACTION"
            android:exported="true">
            <meta-data
                android:name="android.voice_interaction"
                android:resource="@xml/interaction_service" />
            <intent-filter>
                <action android:name="android.service.voice.VoiceInteractionService" />
            </intent-filter>
        </service>
        <service
            android:name=".assistant.BuddyVoiceInteractionSessionService"
            android:permission="android.permission.BIND_VOICE_INTERACTION"
            android:exported="true" />
        <service
            android:name=".assistant.BuddyRecognitionService"
            android:exported="true">
            <intent-filter>
                <action android:name="android.speech.RecognitionService" />
            </intent-filter>
            <meta-data
                android:name="android.speech"
                android:resource="@xml/recognition_service" />
        </service>

        <!-- Quick Settings tile: a pull-down-shade shortcut into a voice session.
             Reuses the same voice launch intent as the widget. -->
        <service
            android:name=".widget.VoiceTileService"
            android:exported="true"
            android:icon="@drawable/ic_notification"
            android:label="@string/voice_tile_label"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
        </service>

        <!-- Don't delete the meta-data below.
             This is used by the Flutter tool to generate GeneratedPluginRegistrant.java -->
        <meta-data
            android:name="flutterEmbedding"
            android:value="2" />
        <!-- Default FCM notification channel (must match aura_default in NotificationService) -->
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_channel_id"
            android:value="aura_default" />
        <!-- Monochrome white icon required for Android status bar (API 21+).
             Full-color icons render as a grey dot; this must be white-on-transparent. -->
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_icon"
            android:resource="@drawable/ic_notification" />
        <!-- PostHog analytics.
             Initialization happens in Dart (main.dart -> PostHogAnalyticsService.initialize) -->
        <meta-data android:name="com.posthog.posthog.AUTO_INIT"
            android:value="false" />
        <meta-data android:name="com.posthog.posthog.API_KEY"
            android:value="phc_CDtz3DmNraHdnJ2w9W7WJNkJ8VANYPBWAcqV2Uf77k5s" />
        <meta-data android:name="com.posthog.posthog.POSTHOG_HOST"
            android:value="https://us.i.posthog.com" />
        <meta-data android:name="com.posthog.posthog.CAPTURE_APPLICATION_LIFECYCLE_EVENTS"
            android:value="true" />
        <!-- Firebase Analytics: turn off automatic native screen tracking. Flutter
             runs inside one Activity, so the automatic screen_view only ever reports
             MainActivity. Real screen names are logged from the route observer
             instead (see AppRouteObserver), so this keeps the dashboard free of that
             native-container noise. -->
        <meta-data
            android:name="google_analytics_automatic_screen_reporting_enabled"
            android:value="false" />
    </application>
    <!-- Required to query activities that can process text, see:
         https://developer.android.com/training/package-visibility and
         https://developer.android.com/reference/android/content/Intent#ACTION_PROCESS_TEXT.

         In particular, this is used by the Flutter engine in io.flutter.plugin.text.ProcessTextPlugin. -->
    <!-- Microphone: required for voice capture and wake word detection -->
    <uses-permission android:name="android.permission.RECORD_AUDIO"/>
    <!-- Audio routing: in-keyboard voice sets communication mode + requests audio focus -->
    <uses-permission android:name="android.permission.MODIFY_AUDIO_SETTINGS"/>
    <!-- Internet: required for WebSocket voice gateway connection -->
    <uses-permission android:name="android.permission.INTERNET"/>
    <!-- Push notifications: required on Android 13+ (API 33+) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS"/>
    <!-- Camera: required to photograph documents for chat attachments -->
    <uses-permission android:name="android.permission.CAMERA"/>
    <!-- Photo library: API 33+ granular media permissions -->
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES"/>
    <!-- Photo library: API 32 and below -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32"/>

    <queries>
        <intent>
            <action android:name="android.intent.action.PROCESS_TEXT"/>
            <data android:mimeType="text/plain"/>
        </intent>
    </queries>
</manifest>
