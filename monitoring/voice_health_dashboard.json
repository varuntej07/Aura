{
  "displayName": "Voice Health",
  "mosaicLayout": {
    "columns": 12,
    "tiles": [
      {
        "xPos": 0, "yPos": 0, "width": 12, "height": 4,
        "widget": {
          "title": "EOU -> first audio (ms): p50 / p95 / p99",
          "xyChart": {
            "thresholds": [
              { "value": 1200.0, "label": "investigate" },
              { "value": 2000.0, "label": "bad" }
            ],
            "yAxis": { "label": "ms", "scale": "LINEAR" },
            "dataSets": [
              {
                "legendTemplate": "p50",
                "plotType": "LINE",
                "timeSeriesQuery": { "timeSeriesFilter": {
                  "filter": "metric.type=\"logging.googleapis.com/user/voice_eou_to_first_audio_ms\"",
                  "aggregation": { "alignmentPeriod": "300s", "perSeriesAligner": "ALIGN_PERCENTILE_50" }
                } }
              },
              {
                "legendTemplate": "p95",
                "plotType": "LINE",
                "timeSeriesQuery": { "timeSeriesFilter": {
                  "filter": "metric.type=\"logging.googleapis.com/user/voice_eou_to_first_audio_ms\"",
                  "aggregation": { "alignmentPeriod": "300s", "perSeriesAligner": "ALIGN_PERCENTILE_95" }
                } }
              },
              {
                "legendTemplate": "p99",
                "plotType": "LINE",
                "timeSeriesQuery": { "timeSeriesFilter": {
                  "filter": "metric.type=\"logging.googleapis.com/user/voice_eou_to_first_audio_ms\"",
                  "aggregation": { "alignmentPeriod": "300s", "perSeriesAligner": "ALIGN_PERCENTILE_99" }
                } }
              }
            ]
          }
        }
      },
      {
        "xPos": 0, "yPos": 4, "width": 6, "height": 4,
        "widget": {
          "title": "LLM TTFT (ms): p50 / p95 / p99",
          "xyChart": {
            "yAxis": { "label": "ms", "scale": "LINEAR" },
            "dataSets": [
              {
