                  "aggregation": { "alignmentPeriod": "300s", "perSeriesAligner": "ALIGN_PERCENTILE_99" }
                } }
              }
            ]
          }
        }
      },
      {
        "xPos": 6, "yPos": 4, "width": 6, "height": 4,
        "widget": {
          "title": "TTS TTFB (ms): p50 / p95 / p99",
          "xyChart": {
            "yAxis": { "label": "ms", "scale": "LINEAR" },
            "dataSets": [
              {
                "legendTemplate": "p50",
                "plotType": "LINE",
                "timeSeriesQuery": { "timeSeriesFilter": {
                  "filter": "metric.type=\"logging.googleapis.com/user/voice_tts_ttfb_ms\"",
                  "aggregation": { "alignmentPeriod": "300s", "perSeriesAligner": "ALIGN_PERCENTILE_50" }
                } }
              },
              {
                "legendTemplate": "p95",
                "plotType": "LINE",
